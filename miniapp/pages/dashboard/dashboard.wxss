.tab-wrap {
  display: flex;
  gap: 12rpx;
  padding: 10rpx;
  flex-wrap: wrap;
}

.recycle-wrap {
  padding-top: 8rpx;
}

.tab {
  flex: 1 1 45%;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  background: #e2e8f0;
  color: #334155;
  font-weight: 600;
}

.tab.active {
  background: #2563eb;
  color: #ffffff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.form-wrap {
  border: 1rpx solid #dbeafe;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 14rpx;
}

.form-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d4ed8;
  margin-bottom: 8rpx;
}

.item-row {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
}

.item-main {
  font-weight: 600;
  color: #0f172a;
}

.item-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.btn-row {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
  background: #f8fafc;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
}

.stat-value {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.picker {
  margin-top: 10rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 10rpx;
  padding: 14rpx;
  color: #334155;
  background: #ffffff;
}

.danger-mini {
  background: #ef4444;
  color: white;
}

.hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.replace-hint {
  color: #1d4ed8;
  font-weight: 600;
}

.input-conflict {
  border: 2rpx solid #ef4444;
  background: #fff1f2;
}

.input-conflict-text {
  color: #ef4444;
}

.conflict-label {
  margin-top: -8rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #ef4444;
  font-weight: 600;
}

.btn-conflict {
  border: 2rpx solid #ef4444;
}

.empty {
  color: #94a3b8;
  padding: 10rpx 0;
}
