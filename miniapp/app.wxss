page {
  background: #f8fafc;
  color: #1f2937;
  font-size: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.input {
  height: 76rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-top: 12rpx;
}

.btn-primary {
  margin-top: 20rpx;
  background: #2563eb;
  color: #ffffff;
  border-radius: 12rpx;
}

.btn-secondary {
  margin-top: 20rpx;
  background: #e2e8f0;
  color: #1e293b;
  border-radius: 12rpx;
}
